  "terms": {
    "title": "\u0627\u0644\u0634\u0631\u0648\u0637 \u0648\u0627\u0644\u0636\u0648\u0627\u0628\u0637",
    "welcome": "\u0645\u0631\u062D\u0628\u064B\u0627 \u0628\u0643 \u0641\u064A VoyageGH. \u0628\u0627\u0633\u062A\u062E\u062F\u0627\u0645\u0643 \u0644\u0645\u0646\u0635\u0627\u062A\u0646\u0627 \u062A\u0642\u0628\u0644 \u0634\u0631\u0648\u0637 \u0648\u0636\u0648\u0627\u0628\u0637\u0646\u0627 \u0627\u0644\u062A\u0627\u0644\u064A\u0629.",
    "s1Title": "1. \u0642\u0628\u0648\u0644 \u0627\u0644\u0634\u0631\u0648\u0637",
    "s1": "\u0628\u0645\u063A\u0636\u0627 \u0648\u0627\u0633\u062A\u062E\u062F\u0627\u0645\u0643 \u0644\u0645\u0646\u0635\u0627\u062A\u0646\u0627 \u062A\u0642\u0628\u0644 \u0627\u0644\u0634\u0631\u0648\u0637 \u0647\u0630\u0647. \u0625\u0630\u0627 \u0644\u0645 \u062A\u0643\u0646 \u0645\u0648\u0627\u0641\u0642\u062A\u064B\u0627 \u064A\u0631\u062C\u0649 \u0627\u0644\u0645\u0646\u0639 \u0639\u0646 \u062E\u062F\u0645\u062A\u0646\u0627.",
    "s2Title": "2. \u0648\u0635\u0641 \u0627\u0644\u062E\u062F\u0645\u0629",
    "s2": "VoyageGH \u0645\u0646\u0635\u0629 \u0633\u0641\u0631 \u0645\u0639\u062A\u0645\u062F\u0629 \u0628\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u062A\u0646\u0627\u0639\u064A \u062A\u0648\u0644\u062F \u0645\u0633\u0627\u0631\u0627\u062A \u0633\u0641\u0631\u064A\u0629 \u0645\u0634\u062E\u0635\u0636\u0629.",
    "s3Title": "3. \u062D\u0633\u0627\u0628\u0627\u062A \u0627\u0644\u0645\u0633\u062A\u062E\u062F\u0645",
    "s3": "\u0623\u0646\u062A \u0645\u0633\u0624\u0648\u0644 \u0639\u0646 \u062D\u0641\u0638 \u0633\u0631\u064A\u0639\u064A\u0627\u062A \u0627\u0644\u062F\u062E\u0648\u0644. \u062A\u0642\u0628\u0644 \u062A\u0642\u062F\u064A\u0645 \u0645\u0639\u0644\u0648\u0645\u0627\u062A \u0635\u062D\u064A\u062D\u0629 \u0648\u0643\u0627\u0645\u0644\u0629.",
    "s4Title": "4. \u0627\u0644\u062D\u062C\u0632\u0627\u062A \u0648\u0627\u0644\u0645\u0639\u0627\u0645\u0644\u0627\u062A",
    "s4": "\u062C\u0645\u064A\u0639 \u0627\u0644\u062D\u062C\u0632\u0627\u062A \u0645\u0639\u062A\u0645\u062F\u0629 \u0628\u0627\u0644\u062A\u0648\u0641\u0631. \u0627\u0644\u0633\u0639\u0631\u0627\u062A \u0645\u0639\u0631\u0636\u0629 \u0628\u062C\u0646\u064A\u0647 \u063A\u064A\u0627\u0646\u0627 (GH\u20B5).",
    "s5Title": "5. \u0633\u064A\u0627\u0633\u0629 \u0627\u0644\u0625\u0644\u063A\u0627\u0621",
    "s5": "\u064A\u0645\u0643\u0646\u0643 \u0625\u0644\u063A\u0627\u0621 \u0627\u0644\u062D\u062C\u0632 \u062D\u062A\u0649 48 \u0633\u0627\u0639\u0629 \u0645\u0646 \u0627\u0644\u0645\u063A\u0627\u062F\u0629.",
    "s6Title": "6. \u0645\u062D\u062A\u0648\u064A\u0627\u062A AI",
    "s6": "\u0645\u0633\u0627\u0631\u0627\u062A \u0627\u0644\u0633\u0641\u0631 \u0645\u0648\u0644\u062F\u0629 \u0628\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u062A\u0646\u0627\u0639\u064A \u0648\u0645\u063A\u0636\u0649 \u0627\u0633\u062A\u062E\u062F\u0627\u0645\u0647\u0627 \u0643\u062A\u0648\u0635\u064A\u0627\u062A.",
    "s7Title": "7. \u0645\u0631\u0627\u062C\u0639\u0627\u062A \u0627\u0644\u0645\u0633\u062A\u062E\u062F\u0645\u064A\u0646",
    "s7": "\u0628\u0625\u0631\u0633\u0627\u0644 \u0645\u0631\u0627\u062C\u0639 \u062A\u0642\u0636\u0639 \u0644\u0645\u0634\u0631\u0648\u0639 \u063A\u064A\u0631 \u062D\u0635\u0631\u064A \u0644\u0627 \u062E\u0635\u0648\u0635\u064A.",
    "s8Title": "8. \u062A\u062D\u062F\u064A\u062F \u0627\u0644\u0645\u0633\u0624\u0648\u0644\u064A\u0629",
    "s8": "\u0644\u0627 \u064A\u062A\u0645 \u062A\u0634\u0643\u0644 VoyageGH \u0639\u0646 \u0623\u064A \u0623\u0636\u0631\u0627\u0631 \u0646\u0627\u062A\u062C\u0629 \u0645\u0646 \u0627\u0633\u062A\u062E\u062F\u0627\u0645 \u0627\u0644\u062E\u062F\u0645\u0629.",
    "s9Title": "9. \u062A\u063A\u064A\u064A\u0631\u0627\u062A \u0627\u0644\u0634\u0631\u0648\u0637",
    "s9": "\u0646\u062D\u0641\u0638 \u0639\u0644\u0649 \u062D\u0642 \u062A\u063A\u064A\u064A\u0631 \u0647\u0630\u0647 \u0627\u0644\u0634\u0631\u0648\u0637 \u0641\u064A \u0623\u064A \u0648\u0642\u062A.",
    "lastUpdated": "\u0622\u062E\u0631 \u062A\u062D\u062F\u064A\u062B: \u064A\u0648\u0644\u064A\u0648 2025"
  },
  "privacy": {
    "title": "\u0633\u064A\u0627\u0633\u0629 \u0627\u0644\u062E\u0635\u0648\u0635\u064A\u0629",
    "intro": "\u062E\u0635\u0648\u0635\u064A\u062A\u0643 \u0645\u0647\u0645\u0629 \u0644\u062F\u064A\u0646\u0627. \u062A\u0634\u0631\u062D \u0647\u0630\u0647 \u0627\u0644\u0633\u064A\u0627\u0633\u0629 \u0643\u064A\u0641 \u062A\u062C\u0645\u0639 VoyageGH \u0645\u0639\u0644\u0648\u0645\u0627\u062A\u0643 \u0627\u0644\u0634\u062E\u0635\u064A\u0629.",
    "s1Title": "1. \u0627\u0644\u0645\u0639\u0644\u0648\u0645\u0627\u062A \u0627\u0644\u0630\u064A \u0646\u062C\u0645\u0639\u0647\u0627",
    "s1": "\u0646\u062C\u0645\u0639 \u0627\u0644\u0645\u0639\u0644\u0648\u0645\u0627\u062A \u0627\u0644\u062A\u064A \u062A\u0642\u062F\u0645\u0647\u0627 \u0628\u0634\u0643\u0644 \u0645\u0628\u0627\u0634\u0631.",
    "s2Title": "2. \u0643\u064A\u0641 \u0646\u0633\u062A\u062E\u062F\u0645 \u0645\u0639\u0644\u0648\u0645\u0627\u062A\u0643",
    "s2": "\u0646\u0633\u062A\u062E\u062F\u0645 \u0645\u0639\u0644\u0648\u0645\u0627\u062A\u0643 \u0644\u062A\u0642\u062F\u064A\u0645 \u0648\u062A\u062D\u0633\u064A\u0646 \u062E\u0635\u0648\u0645\u0646\u0627.",
    "s3Title": "3. \u0623\u0645\u0627\u0646 \u0627\u0644\u0628\u064A\u0627\u0646\u0627\u062A",
    "s3": "\u0646\u0637\u0628\u0642 \u0625\u0637\u0631\u0627\u0642\u0627\u062A \u0623\u0645\u0627\u0646 \u0642\u064A\u0627\u0633\u064A\u0629 \u0644\u062D\u0641\u0638 \u0628\u064A\u0627\u0646\u0627\u062A\u0643 \u0627\u0644\u0634\u062E\u0635\u064A\u0629.",
    "s4Title": "4. \u062E\u062F\u0645\u0627\u062A \u0627\u0644\u0637\u0631\u0641 \u0627\u0644\u062B\u0627\u0644\u062B",
    "s4": "\u0646\u0633\u062A\u062E\u062F\u0645 \u062E\u062F\u0645\u0627\u062A \u0637\u0631\u0641 \u062B\u0627\u0644\u062B (Clerk \u0644\u0644\u062A\u0639\u0631\u064A\u0641).",
    "s5Title": "5. \u062C\u0631\u0648\u0643\u0648\u0643\u0627\u062A",
    "s5": "\u0646\u0633\u062A\u062E\u062F\u0645 \u062C\u0631\u0648\u0643\u0648\u0643\u0627\u062A \u0623\u0633\u0627\u0633\u064A\u0629 \u0644\u0639\u0645\u0644 \u062C\u0644\u0633\u062A\u0643.",
    "s6Title": "6. \u062D\u0642\u0648\u0642\u0643",
    "s6": "\u0644\u0643 \u0627\u0644\u062D\u0642 \u0641\u064A \u0627\u0644\u0648\u0635\u0648\u0644 \u0625\u0644\u0649 \u0628\u064A\u0627\u0646\u0627\u062A\u0643 \u0627\u0644\u0634\u062E\u0635\u064A\u0629 \u0623\u0648 \u062D\u0630\u0641\u0647\u0627.",
    "s7Title": "7. \u062E\u0635\u0648\u0635\u064A\u0629 \u0627\u0644\u0623\u0637\u0641\u0627\u0644",
    "s7": "\u062E\u062F\u0645\u0646\u0627 \u063A\u064A\u0631 \u0645\u0648\u062C\u0647 \u0644\u0644\u0623\u0634\u062E\u0627\u0635 \u0642\u0628\u0644 18 \u0639\u0627\u0645\u0627\u064B.",
    "s8Title": "8. \u062A\u063A\u064A\u064A\u0631\u0627\u062A \u0647\u0630\u0647 \u0627\u0644\u0633\u064A\u0627\u0633\u0629",
    "s8": "\u0646\u0631\u062E\u0635 \u062A\u062D\u062F\u064A\u062B \u0647\u0630\u0647 \u0627\u0644\u0633\u064A\u0627\u0633\u0629 \u0628\u0639\u062F \u0627\u0644\u0645\u062A\u0645\u0627\u0645.",
